+static __inline void ADPCM_DecodeBlock8(ADPCM_Decode_t *decp, u8 filter_range,
+		const u8 *blockp, int src_inc, short *destp, int inc) {
+	int i;
+	int range, filterid;
+	s32 fy0, fy1;
+
+	filterid = (filter_range >> 4) & 0x0f;
+	range = filter_range & 0x0f;
+	fy0 = decp->y0;
+	fy1 = decp->y1;
+
+	for (i = 0; i < BLKSIZ; i++, blockp += src_inc) {
+		s32 sample = (s16)((u16)*blockp << 8) >> range;
+		sample *= 1 << SH;
+		sample -= (IK0(filterid) * fy0 + IK1(filterid) * fy1) >> SHC;
+		fy1 = fy0;
+		fy0 = sample;
+		XACLAMP(sample, (int)(-32768u << SH), 32767 << SH);
+		*destp = sample >> SH;
+		destp += inc;
+	}
+
+	decp->y0 = fy0;
+	decp->y1 = fy1;
+}
